# Tesla-PVPC - Environment Variables
# Copy this file to .env and fill in your values: cp .env.example .env
# Tokens go here (protected by .gitignore), non-sensitive config goes in config.json

# ── Tessie API (required for real vehicle) ──
# Get your token at https://tessie.com/developer
# Leave empty to run in DEBUG MODE (simulated vehicle for testing)
TESSIE_TOKEN=tk_your_tessie_token_here
VIN=LRW3E7FSXXXXXXXXX

# ── ESIOS / Red Eléctrica (optional, falls back to public REData) ──
# Request your token: consultasios@ree.es
ESIOS_TOKEN=your_esios_token_here

# ── Telegram Bot (optional) ──
# Create a bot via @BotFather and get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
