# AutoChargeTesla - Environment Variables
# Copy this file to .env and fill in your values: cp .env.example .env

# ── Tessie API ──
# Get your token at https://tessie.com/developer
# Leave empty to run in DEBUG MODE (simulated vehicle for testing)
TESSIE_TOKEN=tk_your_tessie_token_here
VIN=LRW3E7FSXXXXXXXXX

# ── ESIOS (Red Eléctrica) ──
# Request your token by emailing consultasios@ree.es
ESIOS_TOKEN=your_esios_token_here

# ── Charging Settings ──
MAX_PRICE_CENTS_PER_KWH=10
MAX_CHARGER_POWER_KW=3.3
BATTERY_CAPACITY_KWH=75
MIN_BATTERY_PCT=70
TARGET_TIME=19:00
STRICT_MODE=true
CHARGING_EFFICIENCY=0.9
CHECK_INTERVAL_MINUTES=15

# ── Telegram Bot (optional) ──
# Create a bot via @BotFather and get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
